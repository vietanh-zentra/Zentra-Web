# Zentra Monorepo — Environment Variables
# Copy this file to .env and fill in your values

# --------------------------
# MT5 Python Service
# --------------------------
MT5_API_KEY=your-secret-api-key-change-in-production
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_SERVICE_PORT=5000
LOG_LEVEL=INFO
FLASK_DEBUG=false

# --------------------------
# Node.js Database & API
# --------------------------
PORT=3000
MONGODB_URL=mongodb://127.0.0.1:27017/zentra-db
JWT_SECRET=thisisasamplesecret
JWT_ACCESS_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=30
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10
JWT_VERIFY_EMAIL_EXPIRATION_MINUTES=10

# MT5 Engine URL (Where Node.js forwards MT5 requests)
# Use http://127.0.0.1:5000 for local development without Docker
# Use http://host.docker.internal:5000 if Node.js runs in Docker but Python on Windows host
MT5_ENGINE_URL=http://127.0.0.1:5000
